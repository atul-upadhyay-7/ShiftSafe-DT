# ShiftSafe-DT Environment Variables
# Copy to .env.local: cp .env.example .env.local

# Weather API (OpenWeatherMap) — free key from openweathermap.org/api
OPENWEATHER_API_KEY=demo

# Air Quality API (AQICN) — free key from aqicn.org/data-platform/token
AQICN_API_KEY=demo

# Protects the /api/triggers/cron endpoint from unauthorized calls
CRON_SECRET=your_secret_here

