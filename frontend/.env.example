# ShiftSafe-DT Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Weather API (OpenWeatherMap) ───
# Get your free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=demo

# ─── Air Quality API (AQICN) ───
# Get your free key: https://aqicn.org/data-platform/token/
AQICN_API_KEY=demo

# ─── AI Engine URL ───
# The Python FastAPI AI Risk Engine URL (default: local)
AI_ENGINE_URL=http://localhost:8000
