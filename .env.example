# ShiftSafe-DT Environment Variables
# Copy to .env.local before running: cp .env.example .env.local

# Database
# Primary: Neon Serverless Postgres connection string
# Fallback: when unset, ShiftSafe uses local SQLite at .data/shiftsafe.db
DATABASE_URL=
# Optional: retry transient Neon fetch/connectivity errors (default: 2)
NEON_QUERY_RETRIES=2
# Optional: base retry backoff delay in ms (default: 150)
NEON_QUERY_RETRY_DELAY_MS=150

# CRON Secret — protects the automated trigger endpoint /api/triggers/cron
CRON_SECRET=your_secret_here

# Admin portal authentication (required in production)
ADMIN_EMAIL=admin@example.com
# SHA-256 hash of admin password
# Example: node -e "console.log(require('crypto').createHash('sha256').update('your-password').digest('hex'))"
ADMIN_PASSWORD_HASH=
# Optional local-development fallback password when ADMIN_PASSWORD_HASH is not set
ADMIN_DEV_PASSWORD=local-dev-admin
ADMIN_SESSION_SECRET=replace_with_long_random_secret
WORKER_SESSION_SECRET=replace_with_long_random_secret

# OTP demo code (for local/demo only). In production use real OTP integration.
OTP_DEMO_CODE=
NEXT_PUBLIC_SHOW_DEMO_OTP=false
NEXT_PUBLIC_DEMO_OTP_HINT=

# Optional: Real weather data (leave blank for demo mock data)
OPENWEATHER_API_KEY=
AQICN_API_KEY=
